# ─── App ────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
APP_BASE_URL=http://localhost:3000
FRONTEND_URL=http://localhost:3001

# Comma-separated list of allowed CORS origins
# Use * for development only — restrict in production!
CORS_ORIGINS=http://localhost:3001

# Store info (used for shipping origin)
STORE_NAME="My ClickDz Store"
STORE_PHONE="+213555000000"
STORE_ADDRESS="123 Rue Didouche Mourad, Algiers"
STORE_WILAYA_CODE=16

# ─── Database ───────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/clickdz?schema=public
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=clickdz
DB_PORT=5432

# ─── Redis ──────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── JWT ────────────────────────────────────────────────────────────────
# REQUIRED in production — generate with: openssl rand -hex 32
JWT_SECRET=change-this-to-a-long-random-string-at-least-32-characters
JWT_REFRESH_SECRET=change-this-to-a-different-random-string-at-least-32-chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ─── Rate Limiting ─────────────────────────────────────────────────────
# Uses Redis as backend when available, falls back to in-memory
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_AUTH_MAX=5

# ─── Admin Seed ─────────────────────────────────────────────────────────
ADMIN_EMAIL=admin@clickdz.com
ADMIN_PASSWORD=ChangeMe123!

# ─── SMTP (Email) ──────────────────────────────────────────────────────
# Used for password reset emails, order notifications, etc.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
EMAIL_FROM=noreply@clickdz.shop

# ─── Upload ─────────────────────────────────────────────────────────────
UPLOAD_MAX_SIZE_MB=5
UPLOAD_DIR=./uploads

# ─── Payment: Chargily Pay ──────────────────────────────────────────────
# https://pay.chargily.com — Get your keys from the dashboard
# Supports EDAHABIA & CIB cards (local Algerian payment)
CHARGILY_API_KEY=your_chargily_api_key
CHARGILY_SECRET_KEY=your_chargily_secret_key
CHARGILY_WEBHOOK_SECRET=your_chargily_webhook_secret
CHARGILY_BASE_URL=https://pay.chargily.net/test/api/v2
# Production: https://pay.chargily.net/api/v2

# ─── Payment: SlickPay ──────────────────────────────────────────────────
# https://slick-pay.com — Create an account to get API keys
# Supports EDAHABIA & CIB cards
SLICKPAY_PUBLIC_KEY=your_slickpay_public_key
SLICKPAY_PRIVATE_KEY=your_slickpay_private_key
SLICKPAY_BASE_URL=https://devapi.slick-pay.com/api/v2
# Production: https://prodapi.slick-pay.com/api/v2

# ─── Payment: Stripe ────────────────────────────────────────────────────
# https://dashboard.stripe.com/apikeys
# For international card payments (Visa, Mastercard)
# Note: Stripe does not natively support DZD — configure currency in dashboard
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_stripe_webhook_secret

# ─── Shipping: Yalidine ─────────────────────────────────────────────────
# https://yalidine.com — Register as a merchant
YALIDINE_API_ID=your_yalidine_api_id
YALIDINE_API_TOKEN=your_yalidine_api_token
YALIDINE_BASE_URL=https://api.yalidine.app/v1

# ─── Shipping: ZR Express ───────────────────────────────────────────────
# https://zrexpress.com
ZREXPRESS_API_TOKEN=your_zrexpress_token
ZREXPRESS_BASE_URL=https://api.zrexpress.com/api

# ─── Shipping: EMS (Poste Algérie) ──────────────────────────────────────
EMS_API_KEY=your_ems_api_key
EMS_BASE_URL=https://api.poste.dz/ems/v1

# ─── Shipping: Maystro Delivery ─────────────────────────────────────────
# https://maystro-delivery.com
MAYSTRO_API_TOKEN=your_maystro_token
MAYSTRO_BASE_URL=https://api.maystro-delivery.com
